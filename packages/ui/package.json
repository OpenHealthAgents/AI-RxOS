{
  "name": "@ai-rxos/ui",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./GraphViewer": {
      "import": "./dist/components/scientific/GraphViewer.mjs",
      "require": "./dist/components/scientific/GraphViewer.js"
    },
    "./DockingViewer": {
      "import": "./dist/components/scientific/DockingViewer.mjs",
      "require": "./dist/components/scientific/DockingViewer.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "build": "tsup src/index.ts src/components/scientific/GraphViewer.tsx src/components/scientific/DockingViewer.tsx --format esm,cjs --external react && pnpm run build:css",
    "dev": "tsup src/index.ts src/components/scientific/GraphViewer.tsx src/components/scientific/DockingViewer.tsx --format esm,cjs --external react --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@ai-rxos/eslint-config": "workspace:*",
    "@ai-rxos/typescript-config": "workspace:*",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.4",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-scroll-area": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.26.0",
    "molstar": "^5.11.0",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.10.0",
    "tailwind-merge": "^3.6.0"
  }
}
